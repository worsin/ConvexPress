{
  "name": "convexpress-website",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "convex": "^1.31.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "node -e \"console.error('Disabled: ConvexPress-Website is Convex consumer-only. Run Convex from ConvexPress-Admin.'); process.exit(1)\"",
    "dev:setup": "node -e \"console.error('Disabled: ConvexPress-Website is Convex consumer-only. Configure/deploy Convex in ConvexPress-Admin.'); process.exit(1)\""
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.11.2",
    "@convexpress-website/env": "workspace:*",
    "dotenv": "catalog:",
    "isomorphic-dompurify": "^3.0.0-rc.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@convexpress-website/config": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.13.14",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.8",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  }
}
