{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "CONVEX_URL",
    "VITE_CONVEX_URL",
    "VITE_WORKOS_CLIENT_ID",
    "VITE_ADMIN_APP_URL",
    "VITE_MEILISEARCH_HOST",
    "VITE_MEILISEARCH_KEY",
    "VITE_APP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**", "dist/**", ".vinxi/**"]
    },
    "lint": {
      "dependsOn": [],
      "outputs": []
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
