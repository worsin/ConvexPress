# =============================================================================
# ConvexPress Website — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Lines marked [required] must be set. Lines marked [optional] have defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex — [required]
# Your Convex deployment URL. Must match the admin app's Convex deployment.
# Get this from https://dashboard.convex.dev
# -----------------------------------------------------------------------------
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# -----------------------------------------------------------------------------
# Clerk Auth — [required]
# Clerk publishable key for client-side authentication.
# Get this from https://dashboard.clerk.com
# -----------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# -----------------------------------------------------------------------------
# Admin App Link — [optional]
# URL of the ConvexPress admin app. Used for the admin bar "Edit in Admin" links.
# -----------------------------------------------------------------------------
VITE_ADMIN_APP_URL=http://localhost:4105

# -----------------------------------------------------------------------------
# Search — Meilisearch — [optional]
# Only needed if using Meilisearch for full-text search on the website
# -----------------------------------------------------------------------------
# VITE_MEILISEARCH_HOST=https://meilisearch.your-domain.com
# VITE_MEILISEARCH_KEY=your_meilisearch_search_api_key_here

# -----------------------------------------------------------------------------
# Site URL — [optional]
# Public URL of this website. Used for canonical URLs, OG tags, etc.
# -----------------------------------------------------------------------------
# VITE_APP_URL=https://your-site.com

# -----------------------------------------------------------------------------
# Security — [optional]
# Comma-separated list of allowed redirect hosts (for OAuth, login flows, etc.)
# -----------------------------------------------------------------------------
# VITE_ALLOWED_REDIRECT_HOSTS=your-site.com,admin.your-site.com
