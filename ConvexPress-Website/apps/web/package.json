{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "serve": "vite preview",
    "dev": "vite dev",
    "lint": "oxlint src vite.config.ts --quiet --max-warnings 0 && cd ../../.. && oxlint scripts/website --quiet --max-warnings 0",
    "check-types": "tsc --noEmit",
    "check:seo": "node ../../../scripts/website/check-seo-routes.mjs",
    "check:bundle": "node ../../../scripts/website/check-bundle.mjs",
    "check:smoke:browser": "node ../../../scripts/website/website-browser-smoke.mjs",
    "smoke:ssr": "node ../../../scripts/website/smoke-ssr.mjs",
    "test:smoke": "playwright test",
    "test:smoke:ui": "playwright test --ui",
    "test:smoke:headed": "playwright test --headed",
    "quality": "bun run lint && bun run check-types && bun run build && bun run check:seo && bun run check:bundle && bun run smoke:ssr && bun run check:smoke:browser",
    "auth:provision": "echo 'User provisioning is now handled via Clerk dashboard'",
    "auth:list": "echo 'User listing is now handled via Clerk dashboard'"
  },
