{
  "name": "convexpress-admin",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "convex": "^1.39.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "check:guardrails": "node scripts/check-admin-guardrails.mjs",
    "check:blocks": "node scripts/check-block-catalog.mjs",
    "check:smoke": "node scripts/check-admin-smoke.mjs",
    "check:smoke:browser": "node scripts/admin-browser-smoke.mjs",
    "dev:native": "turbo -F @convexpress/desktop dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @convexpress-admin/backend dev",
    "dev:setup": "turbo -F @convexpress-admin/backend dev:setup"
  },
  "dependencies": {
    "@convexpress-admin/env": "workspace:*",
    "dotenv": "catalog:",
    "lowlight": "^3.3.0",
    "sharp": "^0.34.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@convexpress-admin/config": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.14",
    "convex": "^1.39.1",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.8",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  }
}
