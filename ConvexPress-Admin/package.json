{
  "name": "convexpress-admin",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "convex": "^1.31.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @convexpress-admin/backend dev",
    "dev:setup": "turbo -F @convexpress-admin/backend dev:setup",
    "test:shipping": "bun test packages/backend/convex/shipping/__tests__/"
  },
  "dependencies": {
    "@convexpress-admin/env": "workspace:*",
    "@tiptap/extension-subscript": "^3.19.0",
    "@tiptap/extension-superscript": "^3.19.0",
    "dotenv": "catalog:",
    "lowlight": "^3.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@convexpress-admin/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.8",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  }
}
