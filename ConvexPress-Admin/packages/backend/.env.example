# =============================================================================
# ConvexPress Backend (Convex) — Environment Variables
# =============================================================================
# These are server-side env vars set via `npx convex env set KEY value`
# or in the Convex dashboard under Settings > Environment Variables.
# This file documents the variables used by the Convex backend functions.
#
# Copy this file to .env.local for local `npx convex dev` usage.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex Deployment — [required]
# -----------------------------------------------------------------------------
CONVEX_DEPLOYMENT=prod:your-deployment-name
CONVEX_DEPLOY_KEY=prod:your-deployment-name|your_deploy_key_here
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site

# =============================================================================
# AUTH — [required]
# =============================================================================

# JWT signing key for local admin auth (PEM-encoded P-256 PKCS8 private key for ES256)
AUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_p256_pkcs8_private_key_here\n-----END PRIVATE KEY-----"

# Issuer URL for JWT validation (your Convex site URL or custom domain).
# Tokenless local first-admin setup is allowed only when this is explicitly
# set to localhost, 127.0.0.1, or ::1.
AUTH_ISSUER_URL=https://your-deployment.convex.site

# Browser origins allowed to call /auth/login, /auth/refresh, and /auth/logout.
# Include the hosted admin origin and any intentional local development origins.
# AUTH_ALLOWED_ORIGINS=https://admin.example.com,http://localhost:4105,http://127.0.0.1:4105
# AUTH_ADMIN_ORIGIN=https://admin.example.com
# AUTH_ALLOW_LOCALHOST_ORIGINS=false
# AUTH_ALLOW_NULL_ORIGIN=true

# One-time desktop server-mode setup token. The desktop setup wizard generates
# and sets this automatically for first-admin creation on fresh deployments.
# Non-local deployments require this token unless public browser setup is
# explicitly enabled below.
# FIRST_ADMIN_SETUP_SECRET=generated_by_desktop_setup

# Explicit escape hatch for web-only installs that intentionally allow the
# public first-admin setup action to run without FIRST_ADMIN_SETUP_SECRET.
# Never enable on production unless you accept that takeover surface.
# CONVEXPRESS_ALLOW_PUBLIC_FIRST_ADMIN_SETUP=false

# Dev-only helper gate for local smoke-test admin provisioning. Never enable on
# production deployments. If enabled, provisionSmokeAdmin also requires callers
# to pass the matching CONVEXPRESS_DEV_INTERNALS_TOKEN.
# CONVEXPRESS_ENABLE_DEV_INTERNALS=false
# CONVEXPRESS_DEV_INTERNALS_TOKEN=generate_a_long_random_local_only_token

# =============================================================================
# CLERK INTEGRATION — [required if using Clerk on the website]
# =============================================================================

# Clerk secret key for server-side API calls (password sync, user management)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Clerk webhook secret for verifying Clerk webhook payloads
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret_here

# Clerk JWT issuer domain for token validation
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev

# =============================================================================
# EMAIL — Resend — [optional, required for transactional email]
# =============================================================================

# Resend API key for transactional email, invites, notifications, and receipts
# RESEND_API_KEY=re_your_resend_api_key_here

# Resend webhook signing secret
# RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret_here

# =============================================================================
# SEARCH — Meilisearch — [optional, required for external search]
# =============================================================================

# Meilisearch host and API key for global content indexing/search
# MEILISEARCH_HOST=https://meilisearch.your-domain.com
# MEILISEARCH_API_KEY=your_meilisearch_api_key_here

# =============================================================================
# AI — [optional, required for AI generation/research features]
# =============================================================================

# Set the provider key that matches Settings > AI provider.
# OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
# OPENAI_API_KEY=sk-your_openai_key_here
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Optional OpenAI image key override; falls back to OPENAI_API_KEY when unset.
# OPENAI_IMAGE_API_KEY=sk-your_openai_image_key_here

# Tavily key for research-assisted generation.
# TAVILY_API_KEY=tvly-your_tavily_key_here

# =============================================================================
# PAYMENTS — Stripe — [optional, required for commerce features]
# =============================================================================

# Stripe secret key for server-side API calls
# STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Stripe webhook signing secret for verifying webhook payloads
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# =============================================================================
# PAYMENTS — PayPal — [optional, required for PayPal commerce]
# =============================================================================

# PayPal client credentials
# PAYPAL_CLIENT_ID=your_paypal_client_id_here
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# PayPal webhook ID for verifying webhook payloads
# PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# PayPal mode: "sandbox" or "live"
# PAYPAL_MODE=sandbox

# =============================================================================
# GOOGLE SERVICES — [optional, required for address autocomplete]
# =============================================================================

# Google Places API key for checkout address autocomplete.
# GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# =============================================================================
# FORMS SPAM PROTECTION — [optional, required for CAPTCHA-protected forms]
# =============================================================================

# Configure one or more CAPTCHA providers for public forms.
# FORMS_TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_here
# FORMS_HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_here
# FORMS_RECAPTCHA_SECRET_KEY=your_recaptcha_secret_here

# =============================================================================
# SITE — [optional]
# =============================================================================

# Public site URL (used in payment return URLs, email links, etc.)
# SITE_URL=https://your-site.com

# =============================================================================
# SHIPPING — [optional, required for shipping features]
# =============================================================================

# Encryption key for shipping provider credentials stored in the database
# SHIPPING_PROVIDER_ENCRYPTION_KEY=your_32_char_encryption_key_here

# Optional carrier webhook fallback secrets. Per-connection secrets can replace these.
# SHIPSTATION_WEBHOOK_SECRET=your_shipstation_webhook_secret_here
# FEDEX_WEBHOOK_SECRET=your_fedex_webhook_secret_here
# UPS_WEBHOOK_SECRET=your_ups_webhook_secret_here

# =============================================================================
# MEDIA MIGRATION — [optional]
# =============================================================================

# Keep source media URLs during WordPress migration instead of downloading files.
# MEDIA_URL_ONLY_MODE=false

# =============================================================================
# API / WEBHOOKS — [optional, required for outbound webhooks]
# =============================================================================

# Encryption key for webhook secrets stored in the database
# WEBHOOK_SECRET_ENCRYPTION_KEY=your_32_char_encryption_key_here

# =============================================================================
# WORDPRESS SYNC — [optional, required for WP migration]
# =============================================================================

# Encryption key for WordPress site credentials stored in the database
# WP_SYNC_ENCRYPTION_KEY=your_32_char_encryption_key_here

# =============================================================================
# AIRTABLE — [optional, required for Airtable integration]
# =============================================================================

# Airtable personal access token
# AIRTABLE_API_KEY=pat_your_airtable_api_key_here

# Airtable base ID
# AIRTABLE_BASE_ID=appYourBaseIdHere

# =============================================================================
# GOOGLE ANALYTICS 4 — [optional, required for GA4 integration]
# =============================================================================

# GA4 service account JSON (entire JSON key file as a string)
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# GA4 property ID, for example properties/123456789
# GA4_PROPERTY_ID=properties/123456789
