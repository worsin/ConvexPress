# ── Extensions v2 ──────────────────────────────────────────────────────────
# User-installed extensions live in .local folders and must never be
# uploaded to the upstream repo. The per-folder .gitignore inside each
# .local directory preserves its README/.gitignore while excluding all
# other content; these top-level rules are belt-and-suspenders.
apps/web/src/extensions.local/*
!apps/web/src/extensions.local/.gitignore
!apps/web/src/extensions.local/README.md
packages/backend/convex/extensions.local/*
!packages/backend/convex/extensions.local/.gitignore
!packages/backend/convex/extensions.local/README.md

# Convex schema index — autogenerated by scripts/generate-extension-index.mjs.
# Regenerates on predev / predeploy. Never hand-edit.
packages/backend/convex/schema/_extensionsIndex.generated.ts
