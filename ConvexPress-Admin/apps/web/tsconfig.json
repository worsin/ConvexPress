{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "rootDirs": ["."],
    "baseUrl": ".",
    "paths": {
      "@backend/convex/_generated/api": [
        "./src/test-types/convex-api-shim.d.ts"
      ],
      "@/*": ["./src/*"],
      "@backend/*": ["../../packages/backend/*"]
    }
  }
}
