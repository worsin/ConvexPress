# =============================================================================
# ConvexPress Admin — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Lines marked [required] must be set. Lines marked [optional] have defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex — [required]
# Your Convex deployment URLs. Get these from https://dashboard.convex.dev
# -----------------------------------------------------------------------------
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Optional Convex backend env vars for credentialed /auth/* endpoints.
# Comma-separate every browser origin that may call /auth/*.
# Once AUTH_ALLOWED_ORIGINS is set, unlisted localhost origins are denied unless
# AUTH_ALLOW_LOCALHOST_ORIGINS=true is also set.
# Packaged Electron apps load from file:// and require AUTH_ALLOW_NULL_ORIGIN=true.
# AUTH_ALLOWED_ORIGINS=https://admin.example.com,http://localhost:4105,http://127.0.0.1:4105
# AUTH_ALLOW_LOCALHOST_ORIGINS=false
# AUTH_ALLOW_NULL_ORIGIN=true

# -----------------------------------------------------------------------------
# Convex Deployment — [required for deploys]
# Used by the Convex CLI for `npx convex deploy`
# -----------------------------------------------------------------------------
CONVEX_DEPLOYMENT=prod:your-deployment-name
CONVEX_DEPLOY_KEY=prod:your-deployment-name|your_deploy_key_here

# -----------------------------------------------------------------------------
# Search — Meilisearch — [optional]
# Only needed if using Meilisearch for full-text search
# -----------------------------------------------------------------------------
# MEILISEARCH_HOST=https://meilisearch.your-domain.com
# MEILISEARCH_API_KEY=your_meilisearch_api_key_here

# -----------------------------------------------------------------------------
# Website Link — [optional]
# URL of the consumer-facing website (ConvexPress-Website)
# Used for "View on site" links and cross-app navigation
# -----------------------------------------------------------------------------
VITE_CONSUMER_SITE_URL=http://localhost:4106

# -----------------------------------------------------------------------------
# App URL — [optional]
# Public URL of this admin app (used for OAuth callbacks, etc.)
# -----------------------------------------------------------------------------
# VITE_PUBLIC_APP_URL=http://localhost:4105

# -----------------------------------------------------------------------------
# Node Environment — [optional]
# -----------------------------------------------------------------------------
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Playwright smoke tests — [required to run `bun run test:smoke`]
# Credentials for an existing admin user. Used by tests/smoke/auth.setup.ts.
# -----------------------------------------------------------------------------
# ADMIN_SMOKE_USER=admin@example.com
# ADMIN_SMOKE_PASSWORD=your_test_password
